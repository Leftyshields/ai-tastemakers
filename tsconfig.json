{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist/tastemaker",
    "rootDir": "src/tastemaker",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["src/tastemaker/**/*.ts"],
  "exclude": ["src/tastemaker/**/*.test.ts"]
}
