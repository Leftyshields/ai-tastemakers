GITHUB_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
TZ=America/Los_Angeles
DIGEST_TOP_N=10
DIGEST_MIN_STARS=50
DIGEST_SKILLS_MIN_STARS=30
DIGEST_SKILLS_MAX_STARS_BOOTSTRAP=25000
# Optional default edition for CLI (oss | skills)
DIGEST_EDITION=oss
DIGEST_PUSHED_WITHIN_DAYS=30
DIGEST_MAX_STARS_BOOTSTRAP=80000
# Penalize repos featured in recent briefings (0.5 = 50% score cut; lower = fresher picks). Ranking only — not the "New" badge.
DIGEST_SOFT_DEDUP_PENALTY=0.5
DIGEST_SOFT_DEDUP_BRIEFINGS=5

# Optional — Resend daily digest email (skipped if unset)
RESEND_API_KEY=
DIGEST_EMAIL_FROM=AI Tastemakers <digest@epiphoric.com>
DIGEST_SITE_URL=https://leftyshields.github.io/ai-tastemakers
# Ops alert when daily digest verification fails (GitHub Actions secret DIGEST_ALERT_TO)
DIGEST_ALERT_TO=

# Firebase — epiphoric-prod (public web config for subscribe page build)
FIREBASE_PROJECT_ID=epiphoric-prod
FIREBASE_AUTH_DOMAIN=epiphoric-prod.firebaseapp.com
FIREBASE_API_KEY=
FIREBASE_APP_ID=

# Firebase Admin — digest reads subscribers from Firestore (optional if using subscribers.json only)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or single-line JSON: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Optional — post-rank web/HN enrichment (Skills canary; off in production GHA until experiment active)
DIGEST_ENRICH_WEB=0
DIGEST_ENRICH_SHADOW=0
DIGEST_ENRICH_MAX_REPOS=3
DIGEST_ENRICH_MAX_CHARS=1500
# EXPERIMENT_ID=EXP-20260628-web-enrich-skills

# Optional — PostHog analytics (GitHub Pages build only; inject snippet when set)
POSTHOG_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# POSTHOG_PROJECT_ID=  # optional; for API export scripts later
