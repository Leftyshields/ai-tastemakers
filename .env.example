GITHUB_TOKEN=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
TZ=America/Los_Angeles
DIGEST_TOP_N=10
DIGEST_MIN_STARS=50
DIGEST_PUSHED_WITHIN_DAYS=30
DIGEST_MAX_STARS_BOOTSTRAP=80000
# Penalize repos featured in recent briefings (0.5 = 50% score cut; lower = fresher picks)
DIGEST_SOFT_DEDUP_PENALTY=0.5
DIGEST_SOFT_DEDUP_BRIEFINGS=5

# Optional — Resend daily digest email (skipped if unset)
RESEND_API_KEY=
DIGEST_EMAIL_FROM=AI Tastemakers <digest@epiphoric.com>
DIGEST_EMAIL_TO=brianshields@gmail.com
DIGEST_SITE_URL=https://leftyshields.github.io/ai-tastemakers

# Firebase — epiphoric-prod (public web config for subscribe page build)
FIREBASE_PROJECT_ID=epiphoric-prod
FIREBASE_AUTH_DOMAIN=epiphoric-prod.firebaseapp.com
FIREBASE_API_KEY=
FIREBASE_APP_ID=

# Firebase Admin — digest reads subscribers from Firestore (optional if using subscribers.json only)
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or single-line JSON: FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'
