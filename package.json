{
  "name": "ai-tastemakers",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node --test lib/loadGenome.test.js lib/decompose.test.js lib/signaling.test.js lib/guardrails.test.js lib/run.test.js lib/repair.test.js scripts/derive-expression-profiles.test.js scripts/molecules-read_file.test.js",
    "test:instantiate": "node --test scripts/instantiate.test.js",
    "test:digest": "vitest run",
    "digest": "tsx src/tastemaker/cli.ts",
    "digest:skills": "tsx src/tastemaker/cli.ts -- --edition skills",
    "build:digest": "tsc -p tsconfig.json",
    "build:pages": "tsx scripts/build-pages.ts && tailwindcss -i site/assets/input.css -o site/assets/style.css --minify",
    "subscribers:add": "tsx scripts/add-subscriber.ts",
    "subscribers:seed-firestore": "tsx scripts/seed-subscribers-firestore.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^16.4.7",
    "firebase-admin": "^13.4.0",
    "resend": "^6.12.4"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "marked": "^18.0.5",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
